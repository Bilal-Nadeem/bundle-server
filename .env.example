# Port the server listens on
PORT=3000

# Host (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
HOST=0.0.0.0

# Secret key required in the x-api-key header for all /api/* requests.
# Leave blank to disable auth (not recommended in production).
API_KEY=change_me_to_a_secure_random_string

# How long to cache results before re-fetching from Roblox (in days).
CACHE_TTL_DAYS=30
